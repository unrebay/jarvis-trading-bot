{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pattern",
  "description": "Торговый паттерн — повторяющаяся ценовая конструкция с чёткими условиями входа",
  "type": "object",
  "required": ["id", "name", "category", "description", "conditions"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Уникальный идентификатор паттерна",
      "example": "pattern_001"
    },
    "name": {
      "type": "string",
      "description": "Название паттерна"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Другие названия / аббревиатуры"
    },
    "category": {
      "type": "string",
      "enum": [
        "liquidity_sweep",
        "imbalance",
        "block",
        "manipulation",
        "structure_break",
        "continuation",
        "reversal"
      ]
    },
    "timeframes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Таймфреймы, на которых паттерн работает",
      "example": ["1h", "4h", "1d"]
    },
    "description": {
      "type": "string",
      "description": "Подробное описание паттерна"
    },
    "conditions": {
      "type": "object",
      "properties": {
        "setup": { "type": "string", "description": "Что должно быть на рынке до паттерна" },
        "trigger": { "type": "string", "description": "Что является сигналом/триггером" },
        "confirmation": { "type": "string", "description": "Что подтверждает вход" },
        "invalidation": { "type": "string", "description": "Что отменяет паттерн" }
      }
    },
    "entry": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["market", "limit", "stop"] },
        "description": { "type": "string" }
      }
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Цели по прибыли"
    },
    "stop_loss": {
      "type": "string",
      "description": "Где ставить стоп"
    },
    "win_rate_estimate": {
      "type": "number",
      "description": "Примерный win-rate в %",
      "minimum": 0,
      "maximum": 100
    },
    "media": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Изображения/видео примеры паттерна"
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "asset": { "type": "string" },
          "timeframe": { "type": "string" },
          "date": { "type": "string" },
          "result": { "type": "string", "enum": ["win", "loss", "breakeven"] },
          "notes": { "type": "string" }
        }
      }
    },
    "related_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "channel": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
