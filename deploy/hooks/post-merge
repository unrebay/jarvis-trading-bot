#!/bin/bash
# .git/hooks/post-merge
# Автоматически запускается после git pull / git merge
# Показывает что изменилось

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'

CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null | wc -l | tr -d ' ')

if [[ "$CHANGED" -gt 0 ]]; then
    echo ""
    echo -e "${GREEN}[JARVIS]${NC} Обновлено файлов: ${YELLOW}${CHANGED}${NC}"
    git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD | head -10 | sed "s/^/  ${BLUE}~${NC} /"
    if [[ "$CHANGED" -gt 10 ]]; then
        echo "  ... и ещё $((CHANGED - 10)) файл(а)"
    fi
    echo ""
fi
