{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic",
  "description": "Topic - a conceptual node in the knowledge graph",
  "type": "object",
  "required": ["id", "name", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^topic_[a-z0-9_]+$",
      "description": "Unique topic identifier"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "Topic name"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Topic description"
    },
    "category": {
      "type": "string",
      "description": "Topic category"
    },
    "parent_topics": {
      "type": "array",
      "items": {"type": "string", "pattern": "^topic_[a-z0-9_]+$"},
      "description": "References to parent topics"
    },
    "child_topics": {
      "type": "array",
      "items": {"type": "string", "pattern": "^topic_[a-z0-9_]+$"},
      "description": "References to child topics"
    },
    "related_lessons": {
      "type": "array",
      "items": {"type": "string", "pattern": "^lesson_[a-z0-9_]+$"},
      "description": "Lessons covering this topic"
    },
    "related_rules": {
      "type": "array",
      "items": {"type": "string", "pattern": "^rule_[a-z0-9_]+$"},
      "description": "Rules related to this topic"
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Topic importance (1-5)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
